<?xml version="1.0" encoding="utf-8"?>
<!--
  Template CRM custom 3CX V20 — Hub Astorya (v2)
  ─────────────────────────────────────────────────────────────────────
  Schéma aligné sur la version officielle (Salesforce/HubSpot).
  Ajouts par rapport à v1 : XmlOnlyParams, RuleValue, Variable, Output.
-->
<Crm Name="HubAstorya" Version="1" Country="FR" SupportsEmojis="true" ListSeparator="," XmlOnlyParams="True">

  <Parameters>
    <Parameter Name="WebhookUrl" Type="String" Parent="General" Editor="String" Title="URL Webhook Hub" Default="https://cqdgecllzyqimfuovrpp.supabase.co/functions/v1/phone-webhook" />
    <Parameter Name="Secret" Type="String" Parent="General" Editor="String" Title="Secret X-3CX-Secret" Default="" />
  </Parameters>

  <Authentication Type="No" />

  <Scenarios>
    <Scenario Id="ContactLookup" Type="REST">
      <Request SkipIf="" Url="[WebhookUrl]" RequestEncoding="Json" RequestType="POST" ResponseType="Json">
        <Headers>
          <Header Key="Content-Type" Value="application/json" />
          <Header Key="X-3CX-Secret" Value="[Secret]" />
        </Headers>
        <PostValues>
          <Value Key="CallerID"   Passed="Number" />
          <Value Key="Extension"  Passed="AgentID" />
          <Value Key="Direction"  Value="inbound" />
          <Value Key="Status"     Value="ringing" />
          <Value Key="Department" Value="ASTO" />
        </PostValues>
      </Request>
      <Rules>
        <Rule Type="Any">
          <RuleValue Path="created" />
        </Rule>
      </Rules>
      <Variables>
        <Variable Name="EventID" Path="created" />
      </Variables>
      <Outputs AllowEmpty="true">
        <Output Type="ContactUrl" Passed="created" />
        <Output Type="FirstName"  Value="Hub" />
        <Output Type="LastName"   Value="Astorya" />
      </Outputs>
    </Scenario>
  </Scenarios>

</Crm>
